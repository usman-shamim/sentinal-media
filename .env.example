# ──────────────────────────────────────────
# Personal Brand Sentinel — Environment Config
# ──────────────────────────────────────────

## PostgreSQL — shared across all services
POSTGRES_PASSWORD=change_me_postgres_password
N8N_DB_PASSWORD=change_me_n8n_password
POSTIZ_DB_PASSWORD=change_me_postiz_password

## n8n
N8N_ENCRYPTION_KEY=change_me_32_char_n8n_key
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_PUBLIC_URL=http://localhost:5678/

## Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_telegram_user_id

## Postiz — API & platform integrations
POSTIZ_API_URL=http://postiz:5000
POSTIZ_API_KEY=your_postiz_api_key
POSTIZ_INTEGRATION_X=postiz_integration_id_for_x
POSTIZ_INTEGRATION_LINKEDIN=postiz_integration_id_for_linkedin
POSTIZ_INTEGRATION_THREADS=postiz_integration_id_for_threads
POSTIZ_INTEGRATION_BLUESKY=postiz_integration_id_for_bluesky
POSTIZ_JWT_SECRET=change_me_postiz_jwt_secret

## Sentinel — behaviour
SCHEDULED_POST_TIME=10:00
WORKER_TIMEOUT_SECONDS=15
SENTINEL_TIMEOUT_SECONDS=20
LOG_LEVEL=INFO

## Janitor
JANITOR_INTERVAL_SECONDS=60
STALE_THRESHOLD_MINUTES=5
MAX_RETRIES=3

## Sentinel → n8n bridge
N8N_WEBHOOK_URL=http://n8n:5678/webhook/approval-request
